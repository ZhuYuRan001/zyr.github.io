---
import Layout from "@components/Layout.astro";
import PixelBackground from "@components/PixelBackground";
import { t, localizedPath } from "../../i18n/utils";
import type { Locale } from "../../i18n/translations";

const base = import.meta.env.BASE_URL;
const locale = (Astro.currentLocale || "zh") as Locale;
---

<Layout>
  <!-- Pixel Background (animates independently) -->
  <PixelBackground client:only="react" />

  <!-- Hero: centered full-screen -->
  <section
    class="flex items-center justify-center h-full px-6"
    style="zIndex: 1; position: relative;"
  >
    <div class="text-center">
      <!-- Speech Bubble -->
      <div class="inline-block pixel-panel mb-8">
        <p
          class="font-['Press_Start_2P'] text-xs md:text-sm text-(--color-text) mb-2"
        >
          {t("home.greeting", locale)}
        </p>
        <p
          class="font-['Pixelify_Sans'] text-base text-(--color-text-secondary)"
        >
          {t("home.prompt", locale)}
        </p>
      </div>

      <!-- RPG Menu -->
      <div class="flex flex-col items-center gap-2">
        <a
          href={localizedPath(base, "blog", locale)}
          class="font-['Pixelify_Sans'] text-lg text-(--color-text) hover:text-(--color-accent) transition-colors duration-150 menu-cursor"
        >
          {t("nav.blog", locale)}
        </a>
        <a
          href={localizedPath(base, "projects", locale)}
          class="font-['Pixelify_Sans'] text-lg text-(--color-text) hover:text-(--color-accent) transition-colors duration-150 menu-cursor"
        >
          {t("nav.projects", locale)}
        </a>
        <a
          href={localizedPath(base, "about", locale)}
          class="font-['Pixelify_Sans'] text-lg text-(--color-text) hover:text-(--color-accent) transition-colors duration-150 menu-cursor"
        >
          {t("nav.about", locale)}
        </a>
      </div>
    </div>
  </section>
</Layout>
