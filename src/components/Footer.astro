---
import { t } from "../i18n/utils";
import type { Locale } from "../i18n/translations";

const base = import.meta.env.BASE_URL;
const { locale } = Astro.props as { locale: Locale };
---

<footer class="pixel-border-t bg-(--color-bg-secondary) z-10">
  <div class="mx-auto max-w-275 px-6 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="font-['Pixelify_Sans'] text-xs text-(--color-text-secondary)">
        &copy; {new Date().getFullYear()} ZYR
      </div>
      <div
        class="flex items-center gap-3 font-['Pixelify_Sans'] text-xs text-(--color-text-secondary)"
      >
        <span>{t("footer.madeWith", locale)}</span>
        <span class="text-(--color-accent) font-bold">Astro</span>
        <span>+</span>
        <span class="text-(--color-accent) font-bold">React</span>
        <span>+</span>
        <span class="text-(--color-accent) font-bold">MDX</span>
      </div>
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/ZhuYuRan001"
          target="_blank"
          rel="noopener noreferrer"
          class="text-(--color-text-secondary) hover:text-(--color-accent) transition-colors duration-150"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
          >
        </a>
        <a
          href={`${base}rss.xml`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-(--color-text-secondary) hover:text-(--color-accent) transition-colors duration-150"
          aria-label="RSS Feed"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M4 11a9 9 0 0 1 9 9"></path><path
              d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"
            ></circle></svg
          >
        </a>
      </div>
    </div>
    <div class="mt-4 pt-4 border-t border-(--color-border-light) text-center">
      <p
        class="font-['Press_Start_2P'] text-[8px] text-(--color-text-secondary) opacity-50"
      >
        LV. ∞ &nbsp;-&nbsp; {t("footer.pressStart", locale)}
      </p>
    </div>
  </div>
</footer>
